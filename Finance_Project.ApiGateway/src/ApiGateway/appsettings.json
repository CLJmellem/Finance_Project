{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information",
      "Polly": "Information"
    }
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY_HERE_MUST_BE_AT_LEAST_64_BYTES_LONG_FOR_HMAC_SHA512",
    "Issuer": "Your-Issuer",
    "Audience": "Your-Audience"
  },
  "CircuitBreaker": {
    "FailureRatio": 0.5,
    "SamplingDurationSeconds": 30,
    "MinimumThroughput": 5,
    "BreakDurationSeconds": 30
  },
  "ReverseProxy": {
    "Routes": {
      "cards-route": {
        "ClusterId": "cards-cluster",
        "AuthorizationPolicy": "RequireAuth",
        "Match": {
          "Path": "/api/cards/{**catch-all}"
        }
      },
      "transactions-route": {
        "ClusterId": "transactions-cluster",
        "AuthorizationPolicy": "RequireAuth",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/v1/Authentication/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "cards-cluster": {
        "Destinations": {
          "cards-api": {
            "Address": "https://localhost:65006"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "transactions-api": {
            "Address": "https://localhost:65010"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "https://localhost:7035"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      }
    }
  },
  "AllowedHosts": "*"
}
